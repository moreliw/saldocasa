// Schema mínimo para Fase 0. Modelos completos (users, households, transactions etc.) entram na Fase 1.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder para Prisma generate não falhar com schema vazio.
// Será removido na Fase 1 junto com a primeira migration real.
model _BootstrapPing {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}
